{
  "name": "@hearthly/hearthly-api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/hearthly-api"
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/hearthly-api/dist/package.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/hearthly-api/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "generate-schema": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx ts-node --project apps/hearthly-api/tsconfig.generate-schema.json apps/hearthly-api/src/generate-schema.ts",
          "cwd": "{workspaceRoot}"
        },
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.ts",
          "!{projectRoot}/src/**/*.spec.ts",
          "!{projectRoot}/src/generate-schema.ts"
        ],
        "outputs": [
          "{projectRoot}/src/schema.gql"
        ]
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run --passWithNoTests",
          "cwd": "apps/hearthly-api"
        }
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@hearthly/hearthly-api:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@hearthly/hearthly-api:build:development"
          },
          "production": {
            "buildTarget": "@hearthly/hearthly-api:build:production"
          }
        }
      }
    }
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs-cls/transactional": "^3.2.0",
    "@nestjs-cls/transactional-adapter-drizzle-orm": "^1.2.3",
    "@nestjs/apollo": "^13.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/terminus": "^11.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.0.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-query-complexity": "^1.1.0",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "nestjs-cls": "^6.2.0",
    "postgres": "^3.4.8",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@nestjs/testing": "^11.0.0",
    "drizzle-kit": "^0.31.10"
  }
}
