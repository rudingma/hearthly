{
  "name": "hearthly-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/hearthly-app/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "dependsOn": ["graphql-codegen"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/hearthly-app",
        "browser": "apps/hearthly-app/src/main.ts",
        "tsConfig": "apps/hearthly-app/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/hearthly-app/public"
          }
        ],
        "styles": ["apps/hearthly-app/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/hearthly-app/src/environments/environment.ts",
              "with": "apps/hearthly-app/src/environments/environment.prod.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "hearthly-app:build:production"
        },
        "development": {
          "buildTarget": "hearthly-app:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "dependsOn": ["graphql-codegen"],
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "hearthly-app:build",
        "port": 4200,
        "staticFilePath": "dist/apps/hearthly-app/browser",
        "spa": true
      }
    },
    "graphql-codegen": {
      "executor": "nx:run-commands",
      "dependsOn": ["@hearthly/hearthly-api:generate-schema"],
      "options": {
        "command": "npx graphql-codegen --config codegen.ts"
      },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/apps/hearthly-api/src/schema.gql",
        "{projectRoot}/src/**/*.graphql",
        "{workspaceRoot}/codegen.ts"
      ],
      "outputs": [
        "{projectRoot}/src/generated/graphql.ts"
      ]
    }
  }
}
