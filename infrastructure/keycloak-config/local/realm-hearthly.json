{
  "realm": "hearthly",
  "enabled": true,
  "displayName": "Hearthly",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "loginTheme": "hearthly",
  "accessTokenLifespan": 36000,
  "ssoSessionIdleTimeout": 2592000,
  "ssoSessionMaxLifespan": 2592000,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Default role for all registered Hearthly users"
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-hearthly",
    "composites": {
      "realm": ["offline_access", "uma_authorization", "user"]
    }
  },
  "authenticationFlows": [
    {
      "alias": "first-broker-auto-link",
      "description": "Create new user or auto-link to existing user by email",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "idp-create-user-if-unique",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10
        },
        {
          "authenticator": "idp-auto-link",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 20
        }
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "first-broker-auto-link",
      "config": {
        "clientId": "940613733500-to8n5v9vql8jfp0kufptrorbmgf8cbja.apps.googleusercontent.com",
        "clientSecret": "GOOGLE_CLIENT_SECRET_PLACEHOLDER",
        "defaultScope": "openid email profile",
        "syncMode": "FORCE",
        "useJwksUrl": "true"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "picture-attribute-importer",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "picture",
        "user.attribute": "picture",
        "syncMode": "INHERIT"
      }
    }
  ],
  "clients": [
    {
      "clientId": "hearthly-app",
      "name": "Hearthly App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*##capacitor://localhost/*"
      },
      "redirectUris": [
        "http://localhost:4200/*",
        "capacitor://localhost/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "hearthly-app",
            "id.token.claim": "false",
            "lightweight.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "picture-token-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "picture",
            "claim.name": "picture",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "lightweight.claim": "false",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "dev@hearthly.dev",
      "email": "dev@hearthly.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "offline_access", "uma_authorization"]
    }
  ]
}
