{
  "uid": "hearthly-overview",
  "title": "Hearthly Cluster Overview",
  "description": "Single-page overview of the Hearthly k3s cluster: node health, resource usage, pod status, and persistent volumes.",
  "tags": ["hearthly", "k3s", "cluster"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d"]
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Cluster Summary",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 1,
      "title": "CPU Usage",
      "description": "Average CPU usage across all nodes",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Memory Usage",
      "description": "Average memory usage across all nodes",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Pods Running",
      "description": "Total number of running pods across all namespaces",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(kube_pod_status_phase{phase=\"Running\"})",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Pod Restarts (24h)",
      "description": "Total container restarts across all pods in the last 24 hours",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(kube_pod_container_status_restarts_total[24h]))",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "Node Health — CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "gauge",
      "id": 10,
      "title": "CPU Usage per Node",
      "description": "CPU utilization percentage per node",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "sizing": "auto",
        "minVizWidth": 200,
        "minVizHeight": 200
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{ instance }}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "Node Health — Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "gauge",
      "id": 11,
      "title": "Memory Usage per Node",
      "description": "Memory utilization percentage per node",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "sizing": "auto",
        "minVizWidth": 200,
        "minVizHeight": 200
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "{{ instance }}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 103,
      "title": "Top Resource Consumers",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "id": 20,
      "title": "Top 10 Pods by Memory",
      "description": "Pods consuming the most memory (working set bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Memory (MB)" },
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "namespace" },
            "properties": [
              { "id": "displayName", "value": "Namespace" },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pod" },
            "properties": [
              { "id": "displayName", "value": "Pod" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false
        },
        "sortBy": [
          { "displayName": "Memory (MB)", "desc": true }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "node": true,
              "service": true,
              "uid": true,
              "image": true,
              "id": true,
              "metrics_path": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, sum by (namespace, pod) (container_memory_working_set_bytes{container!=\"\", container!=\"POD\"}) / 1024 / 1024)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "type": "table",
      "id": 21,
      "title": "Top 10 Pods by CPU",
      "description": "Pods consuming the most CPU (rate over 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "CPU (cores)" },
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "namespace" },
            "properties": [
              { "id": "displayName", "value": "Namespace" },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pod" },
            "properties": [
              { "id": "displayName", "value": "Pod" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false
        },
        "sortBy": [
          { "displayName": "CPU (cores)", "desc": true }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "node": true,
              "service": true,
              "uid": true,
              "image": true,
              "id": true,
              "metrics_path": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[5m])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "type": "row",
      "id": 104,
      "title": "Persistent Volumes",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "bargauge",
      "id": 30,
      "title": "PV Usage %",
      "description": "Persistent volume usage percentage per volume claim",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "sizing": "auto",
        "minVizWidth": 8,
        "minVizHeight": 16,
        "maxVizHeight": 300,
        "namePlacement": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - kubelet_volume_stats_available_bytes / kubelet_volume_stats_capacity_bytes) * 100",
          "legendFormat": "{{ namespace }}/{{ persistentvolumeclaim }}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 105,
      "title": "Pod Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "id": 40,
      "title": "Pods with Restarts",
      "description": "Pods that have restarted at least once in the selected time range",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Restarts" },
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 100 },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "transparent", "value": null },
                  { "color": "yellow", "value": 3 },
                  { "color": "red", "value": 10 }
                ]
              }},
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "namespace" },
            "properties": [
              { "id": "displayName", "value": "Namespace" },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pod" },
            "properties": [
              { "id": "displayName", "value": "Pod" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false
        },
        "sortBy": [
          { "displayName": "Restarts", "desc": true }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "node": true,
              "service": true,
              "uid": true,
              "image": true,
              "id": true,
              "metrics_path": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sort_desc(sum by (namespace, pod) (increase(kube_pod_container_status_restarts_total[24h])) > 0)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "type": "table",
      "id": 41,
      "title": "Pods Not Ready",
      "description": "Pods that are currently not in a Ready condition",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "custom.width", "value": 100 },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "0": { "text": "Not Ready", "color": "red" } } },
                { "type": "value", "options": { "1": { "text": "Ready", "color": "green" } } }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "namespace" },
            "properties": [
              { "id": "displayName", "value": "Namespace" },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pod" },
            "properties": [
              { "id": "displayName", "value": "Pod" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "condition" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false
        },
        "sortBy": [
          { "displayName": "Namespace", "desc": false }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "node": true,
              "service": true,
              "uid": true,
              "image": true,
              "id": true,
              "metrics_path": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_pod_status_ready{condition=\"true\"} == 0",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 40,
  "version": 1,
  "links": []
}
