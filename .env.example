# Local development database
POSTGRES_DB=hearthly
POSTGRES_USER=hearthly
POSTGRES_PASSWORD=hearthly_local
DATABASE_URL=postgresql://hearthly:hearthly_local@localhost:5434/hearthly

# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# Keycloak (local)
KEYCLOAK_ISSUER_URL=http://localhost:8180/realms/hearthly
KEYCLOAK_CLIENT_ID=hearthly-app

# Google Identity Provider (retrieve secret from Infisical)
GOOGLE_CLIENT_SECRET=your-google-client-secret
